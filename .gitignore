# scripts/ holds two kinds of files:
#   1. ad-hoc dev seeds (NOT tracked) — run locally with
#        bun --env-file=../../.env scripts/seed-<name>.ts
#   2. tracked env/deploy tooling (whitelisted below), same deny-all +
#      explicit-allow pattern used for .claude/skills/* above.
scripts/*
!scripts/with-infisical.sh
!scripts/infisical-bootstrap.sh
!scripts/sandbox.ts
!scripts/db
!scripts/db/**
!scripts/r2
!scripts/r2/**
!scripts/vercel
!scripts/vercel/**
!scripts/cache
!scripts/cache/**
!scripts/api
!scripts/api/**
!scripts/cloudflare
!scripts/cloudflare/**