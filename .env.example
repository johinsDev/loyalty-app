# =============================================================================
# loyalty-app .env reference
# =============================================================================
# This file is the canonical list of every variable the repo consumes.
# Copy it to `.env` and fill in. The vars are grouped by where they are
# consumed so you can paste subsets into the right place:
#
#   1. MCP servers (local-only, your shell + .env)
#         Read by Claude Code at MCP-handshake time. NEVER set in Vercel.
#   2. Shared by every runtime
#         Goes in `.env` AND in every Vercel project (web + admin) AND in
#         Trigger.dev project env.
#   3. Web only          → only in apps/web Vercel project.
#   4. Admin only        → only in apps/admin Vercel project.
#   5. Jobs only         → only in Trigger.dev project (packages/jobs).
#   6. Per-service tokens → split per deploy target.
#
# direnv is recommended for local dev (the repo ships an `.envrc`):
#   brew install direnv
#   direnv allow .
# =============================================================================


# =============================================================================
# 1. MCP servers — local-only (do NOT add to Vercel/Trigger)
# =============================================================================
# Read by Claude Code when launching MCP servers from .mcp.json. They never
# need to live on a deploy target. If they aren't in your shell env when
# `claude` starts, the corresponding MCP fails to authenticate.

# --- Better Stack MCP (https://mcp.betterstack.com/) ---
# Two API surfaces, two tokens. The MCP is registered twice in .mcp.json:
#   mcp__better-stack__uptime_*          → BETTER_STACK_API_TOKEN
#   mcp__better-stack-telemetry__*       → BETTER_STACK_TELEMETRY_API_TOKEN
#
# Uptime API token: monitors, heartbeats, status pages, incidents, policies.
#   https://uptime.betterstack.com/team/api-tokens
#   Tab "Team-based tokens" → section "Uptime API tokens" → Create.
BETTER_STACK_API_TOKEN=

# Telemetry API token: sources, dashboards, charts, chart-alerts.
#   https://logs.betterstack.com/team/api-tokens
#   Tab "Telemetry API tokens" → Create (scope to the same team).
BETTER_STACK_TELEMETRY_API_TOKEN=

# --- Slack MCP (@modelcontextprotocol/server-slack, stdio) ---
# Wrapped in .mcp.json with `node_modules/.bin/dotenv -e .env -- ...`,
# so these load from this file automatically (no shell export needed).
# See .claude/skills/slack/SKILL.md for the full app-creation walkthrough.
SLACK_BOT_TOKEN=          # xoxb-… from your Slack app's "Install to workspace"
SLACK_TEAM_ID=            # T0…    from app.slack.com/client/T<ID>/...

# --- Linear MCP (https://mcp.linear.app/mcp) ---
# OAuth flow, no token here.

# --- Vercel MCP (https://mcp.vercel.com/) ---
# OAuth flow, no token here.


# =============================================================================
# 2. Shared by every runtime (web + admin + jobs)
# =============================================================================
# These belong in .env locally and in every deploy target.

# --- Database (Neon) ---
# Pooled connection string from Neon (Settings -> Connection details -> pooled).
# Local Postgres alternative: postgresql://root@localhost:5433/db?sslmode=disable
DATABASE_URL=postgresql://user:password@host/db?sslmode=require&channel_binding=require

# --- Logging knobs (read by every bootstrap module) ---
# Floor: trace | debug | info | warn | error | fatal | silent.
# Production keeps `info`; flip to `debug` from the deploy panel and revert.
LOG_LEVEL=info
# Force a specific channel even when BETTER_STACK_SOURCE_TOKEN_* is present.
# Channels: pino | better-stack | console | silent.
# Leave empty to let the bootstrap pick automatically.
LOG_CHANNEL=


# =============================================================================
# 3. Web only (Vercel project: loyalty-web)
# =============================================================================
# Logger ingest for the customer PWA. Each Better Stack source ships its
# own ingest URL + token, so each service has its own pair.
BETTER_STACK_SOURCE_TOKEN_WEB=
BETTER_STACK_INGESTING_HOST_WEB=


# =============================================================================
# 4. Admin only (Vercel project: loyalty-admin)
# =============================================================================
# Generate with: openssl rand -base64 32 (must be at least 32 chars).
BETTER_AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials.
# Authorized redirect URI: <auth-url>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Logger ingest for admin.
BETTER_STACK_SOURCE_TOKEN_ADMIN=
BETTER_STACK_INGESTING_HOST_ADMIN=


# =============================================================================
# 5. Jobs only (Trigger.dev project for packages/jobs)
# =============================================================================
# https://cloud.trigger.dev → your project → API Keys.
# TRIGGER_PROJECT_ID is required — packages/jobs throws on boot if missing.
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

# Logger ingest for jobs.
BETTER_STACK_SOURCE_TOKEN_JOBS=
BETTER_STACK_INGESTING_HOST_JOBS=


# =============================================================================
# 6. WhatsApp (packages/whatsapp)
# =============================================================================
# Default provider per env (when WHATSAPP_PROVIDER is unset):
#   - local dev:        log      (writes a structured line via @loyalty/log)
#   - preview deploy:   outbox   (rows in whatsapp_outbox; PM + E2E reachable)
#   - production:       twilio   (real send via Twilio API)
#
# Set WHATSAPP_PROVIDER explicitly to override (e.g. "outbox" locally to
# preview messages in the admin panel without writing to Twilio).
WHATSAPP_PROVIDER=

# Twilio credentials. Required in prod (and any env where you set
# WHATSAPP_PROVIDER=twilio). WHATSAPP_FROM is the sender number in
# E.164 without the `whatsapp:` prefix — the SDK adds it.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Folder transport (opt-in for visual previews in local dev). When
# this is set AND WHATSAPP_PROVIDER=folder, each send writes a JSON
# + HTML preview to this directory next to process.cwd().
WHATSAPP_PREVIEW_DIR=

# Outbox E2E endpoint override. By default `/api/whatsapp-outbox`
# returns 404 when VERCEL_ENV=production. Flip to "true" only when
# debugging a prod deploy and you accept the read exposure.
WHATSAPP_OUTBOX_ENDPOINT_ENABLED=


# =============================================================================
# 7. SMS (packages/sms)
# =============================================================================
# Mirror of WhatsApp — same 4 transports (log / folder / outbox /
# twilio), same cascade. Twilio credentials are shared with WhatsApp
# (the same SID + auth token can drive both), but the `FROM` numbers
# differ — one per channel.
#
# Default provider per env (when SMS_PROVIDER is unset):
#   - local dev:        log
#   - preview deploy:   outbox   (rows in sms_outbox; (dev) view reachable)
#   - production:       twilio
SMS_PROVIDER=

# Twilio SMS sender. Required when SMS_PROVIDER=twilio. E.164 format
# (long code, short code, or messaging-service-backed number).
TWILIO_SMS_FROM=

# Folder transport (opt-in for visual previews in local dev). When
# this is set AND SMS_PROVIDER=folder, each send writes a JSON + HTML
# preview to this directory next to process.cwd().
SMS_PREVIEW_DIR=


# =============================================================================
# 8. Cache (packages/cache)
# =============================================================================
# Read-through cache (`@loyalty/cache`). One module per app at
# `apps/{web,admin}/src/lib/cache.ts` wires the manager and picks the
# default provider based on the runtime.
#
# Default provider per env (when CACHE_PROVIDER is unset):
#   - local dev:        memory   (process-local Map with TTL, no network)
#   - preview deploy:   upstash  (REST → survives Vercel cold starts)
#   - production:       upstash  (same — REST avoids socket leaks)
#
# Set CACHE_PROVIDER to override: memory | upstash | redis.
CACHE_PROVIDER=

# Upstash Redis (https://upstash.com/) — required when
# CACHE_PROVIDER=upstash. Copy the "REST" credentials from
# Upstash console → Database → REST API (NOT the redis:// URL).
# Validation in apps/{web,admin}/src/env.ts fails the boot if these
# are missing when upstash is selected.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Traditional Redis (ioredis) — required when CACHE_PROVIDER=redis.
# Use for self-hosted environments or for long-lived processes like
# `packages/jobs` (Trigger.dev). NOT recommended on Vercel: ioredis
# keeps a persistent TCP socket that doesn't survive cold starts well.
REDIS_URL=


# =============================================================================
# 9. Email (packages/email + packages/email-templates)
# =============================================================================
# `@loyalty/email` — provider-agnostic sender (Resend / log / folder /
# outbox). Templates live in `@loyalty/email-templates` as React
# components styled with Tailwind via `<Tailwind>` from
# `@react-email/components`. Live preview while authoring:
#   bun --cwd packages/email-templates dev → http://localhost:3008
#
# Default provider per env (when EMAIL_PROVIDER is unset):
#   - local dev:        log     (one line via @loyalty/log, no network)
#   - preview deploy:   outbox  (rows in email_outbox; (dev) view reachable)
#   - production:       resend  (real send via Resend API)
EMAIL_PROVIDER=

# Resend (https://resend.com/) — required when EMAIL_PROVIDER=resend.
# Token from https://resend.com/api-keys (Domain-scoped recommended).
RESEND_API_KEY=

# Verified sender — required when EMAIL_PROVIDER=resend. Format:
#   notifications@t4.app          (bare address)
#   T4 Loyalty <notifications@t4.app>  (with display name)
# Must be on a verified Resend domain (DNS records configured).
EMAIL_FROM=

# Folder transport (opt-in for HTML previews in local dev). When set
# AND EMAIL_PROVIDER=folder, each send writes a JSON + HTML preview
# to this directory next to process.cwd(). Auto-opens in the browser
# unless CI/PROD.
EMAIL_PREVIEW_DIR=


# =============================================================================
# 10. Optional overrides (only when the cascade isn't enough)
# =============================================================================
# Most of the time these stay empty. The apps derive their public URL with
# this cascade in apps/{web,admin}/lib/app-url.ts:
#
#   1. Browser → window.location.origin
#   2. Server → explicit env var below (this section)
#   3. Server → VERCEL_URL (auto-injected per Vercel deploy)
#   4. Server → localhost:300{2,3}
#
# Set them ONLY when:
#   - You have a custom production domain (e.g. https://app.t4-loyalty.com).
#   - You want cross-app auth testing in preview deploys (admin's preview
#     URL ≠ web's preview URL, so explicit pinning is needed).
NEXT_PUBLIC_APP_URL=
BETTER_AUTH_URL=

# Single-service Better Stack shortcut. Bootstraps prefer the per-service
# vars above; this is the fallback when you only have one service.
BETTER_STACK_SOURCE_TOKEN=
BETTER_STACK_INGESTING_HOST=in.logs.betterstack.com
