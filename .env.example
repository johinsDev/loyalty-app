# --- Database (Neon) ---
# Pooled connection string from your Neon project (Settings -> Connection details)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --- Better Auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of the app issuing the session (admin uses 3000, web uses 3001 in dev)
BETTER_AUTH_URL=http://localhost:3000

# --- Trigger.dev v3 ---
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

# --- Public ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
