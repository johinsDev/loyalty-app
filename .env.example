# =============================================================================
# loyalty-app env reference + Infisical matrix
# =============================================================================
# Infisical is the source of truth for env across dev / preview / prod.
# This file is the human-readable matrix: every variable, which Infisical
# FOLDER it lives in, which ENVIRONMENTS it differs by, and whether its
# value is static or generated on-the-fly by a pipeline.
#
# You normally do NOT keep a hand-written `.env` anymore. Instead:
#   infisical login && infisical init        # one-time, writes .infisical.json
#   bun run env:bootstrap -- --import .env --env dev   # migrate an old .env
#   bun run dev                              # auto-injects via scripts/with-infisical.sh
# Before bootstrap (no .infisical.json) the wrapper falls back to .env /
# direnv, so nothing breaks mid-migration. See .claude/skills/env-deploy.
#
# ── Infisical project: loyalty-app ──
#   environments (slugs):  dev · preview · prod
#   folders (consumer scope, exist in every environment):
#     /shared    consumed by 2+ runtimes (db, providers, Twilio, R2, …)
#     /web       apps/web only (NEXT_PUBLIC_*, web log ingest)
#     /admin     apps/admin only (Better Auth, Google OAuth, admin ingest)
#     /jobs      packages/jobs / Trigger.dev only
#     /partykit  the realtime worker only
#     /mcp       Claude Code MCP + CI tokens — NEVER on a deploy target
#
# ── env differences (read this column before adding a var) ──
#   static    same value you set once per environment
#   on-fly    a pipeline injects/overrides it per run (e.g. preview
#             DATABASE_URL = the per-PR Neon branch — Fase 3 GHA)
#   platform  injected by Vercel itself, NEVER stored in Infisical
#             (VERCEL_URL, VERCEL_ENV, VERCEL_PROJECT_PRODUCTION_URL)
#
# ── matrix (folder · which envs differ · static/on-fly) ──
#   DATABASE_URL ............... /shared  dev≠preview≠prod   on-fly (preview)
#   LOG_LEVEL / LOG_CHANNEL .... /shared  differs            static
#   *_PROVIDER toggles ......... /shared  dev=log preview=outbox prod=real
#   TWILIO_* ................... /shared  preview/prod        static
#   UPSTASH_* / REDIS_URL ...... /shared  preview/prod        static
#   RESEND_API_KEY / EMAIL_FROM  /shared  prod (preview=outbox) static
#   VAPID_* .................... /shared  preview/prod        static
#   REALTIME_AUTH_SECRET ....... /shared  per env             static
#   R2_* ....................... /shared  preview/prod        static
#   NEXT_PUBLIC_APP_URL ........ /web     optional override   static
#   NEXT_PUBLIC_VAPID_PUBLIC_KEY /web     preview/prod        static
#   NEXT_PUBLIC_PARTYKIT_HOST .. /web     preview/prod        static
#   BETTER_STACK_*_WEB ......... /web     prod (no dev)       static
#   BETTER_AUTH_SECRET ......... /admin   per env             static
#   BETTER_AUTH_URL ............ /admin   optional override   static
#   GOOGLE_CLIENT_ID/SECRET .... /admin   preview≠prod (2 OAuth clients) static
#   ADMIN_PREVIEW_EMAIL/PASSWORD /shared  dev+staging only (NOT prod) static
#   BETTER_STACK_*_ADMIN ....... /admin   prod (no dev)       static
#   TRIGGER_PROJECT_ID/SECRET .. /jobs    preview≠prod        static
#   OUTBOX_RETENTION_DAYS ...... /jobs    prod                static
#   BETTER_STACK_*_JOBS ........ /jobs    prod (no dev)       static
#   PARTYKIT_HOST / _PROJECT ... /partykit preview/prod       static
#   BETTER_STACK_API_TOKEN ..... /mcp     dev (prod if differ) static
#   BETTER_STACK_TELEMETRY_* ... /mcp     dev                 static
#   SLACK_BOT_TOKEN / TEAM_ID .. /mcp     dev                 static
#
# Sections below keep the original consumer grouping; each header now
# also states its Infisical folder. direnv (.envrc) still works as the
# pre-Infisical fallback for local-only MCP tokens.
# =============================================================================


# =============================================================================
# 1. MCP servers — local-only (do NOT add to Vercel/Trigger)
# Infisical: folder=/mcp  env=dev (add prod only if a token differs there)
# =============================================================================
# Read by Claude Code when launching MCP servers from .mcp.json. They never
# need to live on a deploy target. If they aren't in your shell env when
# `claude` starts, the corresponding MCP fails to authenticate.

# --- Better Stack MCP (https://mcp.betterstack.com/) ---
# Two API surfaces, two tokens. The MCP is registered twice in .mcp.json:
#   mcp__better-stack__uptime_*          → BETTER_STACK_API_TOKEN
#   mcp__better-stack-telemetry__*       → BETTER_STACK_TELEMETRY_API_TOKEN
#
# Uptime API token: monitors, heartbeats, status pages, incidents, policies.
#   https://uptime.betterstack.com/team/api-tokens
#   Tab "Team-based tokens" → section "Uptime API tokens" → Create.
BETTER_STACK_API_TOKEN=

# Telemetry API token: sources, dashboards, charts, chart-alerts.
#   https://logs.betterstack.com/team/api-tokens
#   Tab "Telemetry API tokens" → Create (scope to the same team).
BETTER_STACK_TELEMETRY_API_TOKEN=

# --- Slack MCP (@modelcontextprotocol/server-slack, stdio) ---
# Wrapped in .mcp.json with `node_modules/.bin/dotenv -e .env -- ...`,
# so these load from this file automatically (no shell export needed).
# See .claude/skills/slack/SKILL.md for the full app-creation walkthrough.
SLACK_BOT_TOKEN=          # xoxb-… from your Slack app's "Install to workspace"
SLACK_TEAM_ID=            # T0…    from app.slack.com/client/T<ID>/...

# --- Infisical MCP (@infisical/mcp, stdio) ---
# Wrapped in .mcp.json with `node_modules/.bin/dotenv -e .env -- ...`,
# so these load from this file automatically (no shell export needed).
# Lets Claude Code manage Infisical itself (create projects/envs/folders,
# set secrets) via a Machine Identity. Create one at Organization →
# Access Control → Identities (Universal Auth) with an org role that can
# create projects (e.g. Admin), then add a Client Secret.
#   https://infisical.com/docs/documentation/platform/identities/universal-auth
INFISICAL_AUTH_METHOD=universal-auth
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=

# --- Linear MCP (https://mcp.linear.app/mcp) ---
# OAuth flow, no token here.

# --- Vercel MCP (https://mcp.vercel.com/) ---
# OAuth flow, no token here.

# --- Resend MCP (resend-mcp, stdio) ---
# Registered in .mcp.json as `RESEND_API_KEY: ${MCP_RESEND_API_KEY}`, so the
# value is read from this file's env (kept separate from the app's
# RESEND_API_KEY in section 9 so the MCP can use its own scoped token).
# Token from https://resend.com/api-keys.
MCP_RESEND_API_KEY=

# --- PostHog MCP (https://mcp.posthog.com/mcp, http) ---
# Registered in .mcp.json with `Authorization: Bearer ${MCP_POSTHOG_API_KEY}`.
# Lets Claude Code manage PostHog (feature flags, experiments, insights).
# Create a PERSONAL API key (phx_…) — NOT the public project key — at
#   https://app.posthog.com/settings/user-api-keys?preset=mcp_server
# The "MCP Server" preset scopes it correctly. Routes to US/EU automatically.
MCP_POSTHOG_API_KEY=


# =============================================================================
# 2. Shared by every runtime (web + admin + jobs)
# Infisical: folder=/shared  env=dev≠preview≠prod  (DATABASE_URL on-fly in preview)
# =============================================================================
# These belong in .env locally and in every deploy target.

# --- Database (Turso / libSQL) ---
# Remote: the libsql:// URL from `turso db show <db> --url`.
# Local dev alternative: a file URL, e.g. file:./local.db (no auth token needed).
DATABASE_URL=libsql://your-db.turso.io
# Auth token from `turso db tokens create <db>`. Required for remote libsql://;
# omit for a local file: URL.
TURSO_AUTH_TOKEN=

# --- Logging knobs (read by every bootstrap module) ---
# Floor: trace | debug | info | warn | error | fatal | silent.
# Production keeps `info`; flip to `debug` from the deploy panel and revert.
LOG_LEVEL=info
# Force a specific channel even when BETTER_STACK_SOURCE_TOKEN_* is present.
# Channels: pino | better-stack | console | silent.
# Leave empty to let the bootstrap pick automatically.
LOG_CHANNEL=

# --- Standalone API Worker (web + admin) ---
# URL of the Hono API Worker on Cloudflare (e.g. https://api.t4diverclub.app, or
# http://localhost:8787 for `wrangler dev`). When SET, the FE tRPC + auth clients
# target it cross-origin (cookies via credentials:include). When UNSET, the apps
# use their same-origin Next `/api/trpc` + `/api/auth` routes (current behaviour)
# — so leaving it empty is a no-op. See the `api-worker` plan.
NEXT_PUBLIC_API_URL=

# The next three are read by the API Worker only (set via `wrangler secret put` /
# Infisical for the Worker; unset for the Next apps → no behaviour change).
#
# Extra Better Auth trusted origins + credentialed-CORS allowlist (CSV). The FE
# subdomains the Worker serves; localhost:3002/3003 are always allowed. Prod:
# https://admin.t4diverclub.app,https://app.t4diverclub.app
BETTER_AUTH_TRUSTED_ORIGINS=
# Session-cookie Domain so sibling FE subdomains send it. Prod: .t4diverclub.app
# Leave UNSET locally (localhost cookies are host-only, shared across ports).
AUTH_COOKIE_DOMAIN=
# Expose email/password sign-in on the Worker issuer. "true" in dev/preview (for
# the seeded preview admin); UNSET/"false" in prod (Google-only by policy).
AUTH_PASSWORD_ENABLED=


# =============================================================================
# 3. Web only (Vercel project: loyalty-web)
# Infisical: folder=/web  env=prod (no dev — pino locally)
# =============================================================================
# Logger ingest for the customer PWA. Each Better Stack source ships its
# own ingest URL + token, so each service has its own pair.
BETTER_STACK_SOURCE_TOKEN_WEB=
BETTER_STACK_INGESTING_HOST_WEB=

# Sentry error tracking (project: loyalty-web). Unset → Sentry is inert
# (local dev). Set in Infisical /web for preview + prod. The DSN is public
# (browser + server read it). ORG/PROJECT/AUTH_TOKEN are build-time only —
# read by withSentryConfig to upload source maps during `next build`.
# NOTE: SENTRY_AUTH_TOKEN must be Plain Text in Vercel (build-time), NOT
# Sensitive — Sensitive vars aren't readable to the build. See
# `.claude/skills/sentry/SKILL.md`.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=


# =============================================================================
# 4. Admin only (Vercel project: loyalty-admin)
# Infisical: folder=/admin  env=per-env (GOOGLE_* differ preview vs prod)
# =============================================================================
# Generate with: openssl rand -base64 32 (must be at least 32 chars).
BETTER_AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials.
# Authorized redirect URI: <auth-url>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Deterministic admin user for preview/dev sign-in. Email/password auth is
# enabled on admin everywhere except prod (VERCEL_ENV=production → Google-only),
# and `bun run db:seed:preview-admin` upserts this user as owner. Infisical
# /shared in dev + staging only — NEVER set in prod.
ADMIN_PREVIEW_EMAIL=admin@preview.test
ADMIN_PREVIEW_PASSWORD=

# Sentry error tracking (project: loyalty-admin). Same shape as web above —
# unset → inert; set in Infisical /admin for preview + prod. SENTRY_AUTH_TOKEN
# stays Plain Text in Vercel (build-time source-map upload).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Logger ingest for admin.
BETTER_STACK_SOURCE_TOKEN_ADMIN=
BETTER_STACK_INGESTING_HOST_ADMIN=


# =============================================================================
# 5. Jobs only (Trigger.dev project for packages/jobs)
# Infisical: folder=/jobs  env=preview≠prod  (synced to Trigger via syncEnvVars, Fase 4)
# =============================================================================
# https://cloud.trigger.dev → your project → API Keys.
# TRIGGER_PROJECT_ID is required — packages/jobs throws on boot if missing.
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

# Logger ingest for jobs.
BETTER_STACK_SOURCE_TOKEN_JOBS=
BETTER_STACK_INGESTING_HOST_JOBS=


# =============================================================================
# 6. WhatsApp (packages/whatsapp)
# Infisical: folder=/shared  dev=log preview=outbox prod=twilio
# =============================================================================
# Default provider per env (when WHATSAPP_PROVIDER is unset):
#   - local dev:        log      (writes a structured line via @loyalty/log)
#   - preview deploy:   outbox   (rows in whatsapp_outbox; PM + E2E reachable)
#   - production:       twilio   (real send via Twilio API)
#
# Set WHATSAPP_PROVIDER explicitly to override (e.g. "outbox" locally to
# preview messages in the admin panel without writing to Twilio).
WHATSAPP_PROVIDER=

# Twilio credentials. Required in prod (and any env where you set
# WHATSAPP_PROVIDER=twilio). WHATSAPP_FROM is the sender number in
# E.164 without the `whatsapp:` prefix — the SDK adds it.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Folder transport (opt-in for visual previews in local dev). When
# this is set AND WHATSAPP_PROVIDER=folder, each send writes a JSON
# + HTML preview to this directory next to process.cwd().
WHATSAPP_PREVIEW_DIR=

# Outbox E2E endpoint override. By default `/api/whatsapp-outbox`
# returns 404 when VERCEL_ENV=production. Flip to "true" only when
# debugging a prod deploy and you accept the read exposure.
WHATSAPP_OUTBOX_ENDPOINT_ENABLED=


# =============================================================================
# 7. SMS (packages/sms)
# Infisical: folder=/shared  dev=log preview=outbox prod=twilio
# =============================================================================
# Mirror of WhatsApp — same 4 transports (log / folder / outbox /
# twilio), same cascade. Twilio credentials are shared with WhatsApp
# (the same SID + auth token can drive both), but the `FROM` numbers
# differ — one per channel.
#
# Default provider per env (when SMS_PROVIDER is unset):
#   - local dev:        log
#   - preview deploy:   outbox   (rows in sms_outbox; (dev) view reachable)
#   - production:       twilio
SMS_PROVIDER=

# Twilio SMS sender. Required when SMS_PROVIDER=twilio. E.164 format
# (long code, short code, or messaging-service-backed number).
TWILIO_SMS_FROM=

# Folder transport (opt-in for visual previews in local dev). When
# this is set AND SMS_PROVIDER=folder, each send writes a JSON + HTML
# preview to this directory next to process.cwd().
SMS_PREVIEW_DIR=


# =============================================================================
# 8. Cache (packages/cache)
# Infisical: folder=/shared  dev=memory preview/prod=upstash
# =============================================================================
# Read-through cache (`@loyalty/cache`). One module per app at
# `apps/{web,admin}/src/lib/cache.ts` wires the manager and picks the
# default provider based on the runtime.
#
# Default provider per env (when CACHE_PROVIDER is unset):
#   - local dev:        memory   (process-local Map with TTL, no network)
#   - preview deploy:   upstash  (REST → survives Vercel cold starts)
#   - production:       upstash  (same — REST avoids socket leaks)
#
# Set CACHE_PROVIDER to override: memory | upstash | redis.
CACHE_PROVIDER=

# Upstash Redis (https://upstash.com/) — required when
# CACHE_PROVIDER=upstash. Copy the "REST" credentials from
# Upstash console → Database → REST API (NOT the redis:// URL).
# Validation in apps/{web,admin}/src/env.ts fails the boot if these
# are missing when upstash is selected.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Traditional Redis (ioredis) — required when CACHE_PROVIDER=redis.
# Use for self-hosted environments or for long-lived processes like
# `packages/jobs` (Trigger.dev). NOT recommended on Vercel: ioredis
# keeps a persistent TCP socket that doesn't survive cold starts well.
REDIS_URL=


# =============================================================================
# 8b. Rate limiting (packages/rate-limit)
# Infisical: folder=/shared  dev=memory preview/prod=upstash
# =============================================================================
# Provider-agnostic rate limiter (`@loyalty/rate-limit`) behind the tRPC
# `rateLimit` middleware. Shares UPSTASH_* / REDIS_URL (above) with the cache.
#
# Default provider per env (when RATE_LIMIT_PROVIDER is unset):
#   - local dev:        memory  (process-local; NOT shared across instances)
#   - preview deploy:   upstash (atomic sliding window across serverless)
#   - production:       upstash (same)
#
# Set RATE_LIMIT_PROVIDER to override: memory | upstash | redis. Memory is
# wrong for serverless prod (each lambda counts independently) — use upstash.
RATE_LIMIT_PROVIDER=


# =============================================================================
# 9. Email (packages/email + packages/email-templates)
# Infisical: folder=/shared  dev=log preview=outbox prod=resend
# =============================================================================
# `@loyalty/email` — provider-agnostic sender (Resend / log / folder /
# outbox). Templates live in `@loyalty/email-templates` as React
# components styled with Tailwind via `<Tailwind>` from
# `@react-email/components`. Live preview while authoring:
#   bun --cwd packages/email-templates dev → http://localhost:3008
#
# Default provider per env (when EMAIL_PROVIDER is unset):
#   - local dev:        log     (one line via @loyalty/log, no network)
#   - preview deploy:   outbox  (rows in email_outbox; (dev) view reachable)
#   - production:       resend  (real send via Resend API)
EMAIL_PROVIDER=

# Resend (https://resend.com/) — required when EMAIL_PROVIDER=resend.
# Token from https://resend.com/api-keys (Domain-scoped recommended).
RESEND_API_KEY=

# Verified sender — required when EMAIL_PROVIDER=resend. Format:
#   notifications@mail.t4diverclub.app                     (bare address)
#   T4 Diver Club <notifications@mail.t4diverclub.app>     (with display name)
# Must be on a verified Resend domain (DNS records configured). The sending
# domain is mail.t4diverclub.app (dedicated subdomain, verified in Resend).
EMAIL_FROM=

# Folder transport (opt-in for HTML previews in local dev). When set
# AND EMAIL_PROVIDER=folder, each send writes a JSON + HTML preview
# to this directory next to process.cwd(). Auto-opens in the browser
# unless CI/PROD.
EMAIL_PREVIEW_DIR=


# =============================================================================
# 10. Push notifications (packages/push)
# Infisical: folder=/shared  (NEXT_PUBLIC_VAPID_PUBLIC_KEY → /web)
# =============================================================================
# `@loyalty/push` — provider-agnostic push sender. Two production
# protocols share the same abstraction: Web Push (browser PWA via
# VAPID + Service Worker) and Expo Push (future native app). The
# `auto` sender fans out per stored token's `platform`.
#
# Default provider per env (when PUSH_PROVIDER is unset):
#   - local dev:        log     (one line via @loyalty/log, no network)
#   - preview deploy:   outbox  (rows in push_outbox; (dev) view reachable)
#   - production:       auto    (fan-out to webpush + expo per token)
#
# Override with PUSH_PROVIDER=log|outbox|webpush|expo|auto.
PUSH_PROVIDER=

# VAPID keys — required when PUSH_PROVIDER=webpush or auto. Generate:
#   bunx web-push generate-vapid-keys
# `VAPID_SUBJECT` is a `mailto:` or HTTPS URL the push service
# operators can contact if your sender misbehaves.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@t4.app

# Expose the VAPID public key to the browser so the client can call
# `pushManager.subscribe({ applicationServerKey })`. Keep in sync with
# VAPID_PUBLIC_KEY above.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Expo access token — optional, enables enhanced security for the
# Expo Push API. Without it, requests work but with less strict rate
# limits. https://docs.expo.dev/push-notifications/sending-notifications/#additional-security
EXPO_ACCESS_TOKEN=


# =============================================================================
# 11. Real-time channel (partykit/ + packages/realtime)
# Infisical: REALTIME_AUTH_SECRET → /shared · PARTYKIT_HOST/_PROJECT → /partykit
#            NEXT_PUBLIC_PARTYKIT_HOST → /web
# =============================================================================
# `@loyalty/realtime` — WebSocket channel via PartyKit (Cloudflare
# Workers + Durable Objects). One party class per concern; the
# customer party is the only one wired today. Push wakes the user
# when offline; realtime lights up the screen they already have open.
#
# Apps fall back to a `FakeRealtime` (logs only, no network) when
# these vars are missing — keeps local dev working without partykit.
#
# PARTYKIT_HOST: deployed worker host. Cloudflare default:
#   <project>.<your-partykit-user>.partykit.dev
# Or a custom CNAME on a domain you own.
PARTYKIT_HOST=

# Matches `name` in partykit.json (currently "loyalty-realtime").
PARTYKIT_PROJECT=loyalty-realtime

# HS256 secret shared by Next (signs tickets + HMAC headers) and the
# PartyKit server (verifies them). Same value MUST be set both in
# Vercel and pushed to PartyKit via:
#   partykit env push REALTIME_AUTH_SECRET --value "$REALTIME_AUTH_SECRET"
# Generate with: openssl rand -base64 48
REALTIME_AUTH_SECRET=

# Exposed to the browser so the React hook can open WebSockets to
# the right host. Same value as PARTYKIT_HOST.
NEXT_PUBLIC_PARTYKIT_HOST=

# Per-PR preview isolation: prefixes the room body (e.g. pr-7-) so
# previews sharing one staging party don't collide. The preview
# workflow pins `pr-<n>-`; leave EMPTY in prod + local. Applied
# server-side only (ticket service + publisher) — the client follows
# the prefixed room the ticket grants.
REALTIME_ROOM_PREFIX=


# =============================================================================
# 12. Storage (packages/storage)
# Infisical: folder=/shared  dev=local preview/prod=r2
#            preview shares ONE bucket, prefix pr-<n>/ (Fase 3)
# =============================================================================
# `@loyalty/storage` — provider-agnostic file storage with presigned
# upload URLs. Three providers: memory (tests / preview fallback),
# local (filesystem under `.storage/`), r2 (Cloudflare R2).
#
# Default per env (when STORAGE_PROVIDER is unset):
#   - local dev:        local
#   - preview deploy:   memory (or r2 if R2 keys present)
#   - production:       r2 (required, fails boot if keys missing)
#
# Override with STORAGE_PROVIDER=memory|local|r2.
STORAGE_PROVIDER=

# Cloudflare R2 — required when STORAGE_PROVIDER=r2. Get these from
# Cloudflare dashboard → R2 → Manage API Tokens → Create token scoped
# to the bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Optional. Public CDN URL for the bucket (Cloudflare's
# `pub-<hash>.r2.dev` or a custom CNAME). Required when any disk is
# `isPublic: true`. Leave empty if you only serve files via signed
# URLs.
R2_PUBLIC_URL=

# NOTE: storage's HMAC tokens for local/memory providers reuse
# `REALTIME_AUTH_SECRET` (above). No separate secret needed.


# =============================================================================
# 12b. Product analytics (packages/analytics)
# Infisical: folder=/shared  dev=null preview=null prod=posthog
# =============================================================================
# Provider-agnostic analytics (`@loyalty/analytics`). Both server (tRPC,
# Next server) and the React client read the same PostHog project key —
# project keys (`phc_...`) are public and embeddable.
#
# Default provider per env (when ANALYTICS_PROVIDER is unset):
#   - local dev:        null     (no events sent)
#   - preview deploy:   null     (don't pollute prod analytics)
#   - production:       posthog
#
# Override with ANALYTICS_PROVIDER=null|posthog. To test in a single
# preview, pin ANALYTICS_PROVIDER=posthog branch-scoped on Vercel —
# events arrive in PostHog tagged `environment=preview`.
ANALYTICS_PROVIDER=

# PostHog project credentials. Public — safe to embed (the project key
# only authorises ingestion). Required when ANALYTICS_PROVIDER=posthog.
# NOTE: provider selection keys off the PRESENCE of this key — set it and
# both analytics (FE) and flags (FE + Worker, fetch driver) go live; unset
# it and both fall to `null`. Wired in Infisical /shared (dev + staging +
# prod). The FE reads it from /shared; the prod Worker gets it as a committed
# [var] in apps/api/wrangler.toml (it doesn't read /shared).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# =============================================================================
# 12c. Feature flags (packages/feature-flags)
# Infisical: folder=/shared  dev=posthog preview=posthog prod=posthog (gates on key)
# =============================================================================
# Provider-agnostic feature flags + A-B testing (`@loyalty/feature-flags`).
# Reuses the SAME `NEXT_PUBLIC_POSTHOG_*` envs as `@loyalty/analytics`
# (one PostHog project covers both products).
#
# Default provider per env (when FEATURE_FLAGS_PROVIDER is unset):
#   - local dev:        null    (returns the supplied default; no network)
#   - preview deploy:   posthog (gating + A-B testable per PR)
#   - production:       posthog
#
# Different cascade from analytics — flags drive UI behaviour, so previews
# evaluate against real flags by default so you can test the gating in PRs.
# Override with FEATURE_FLAGS_PROVIDER=null|posthog per-env.
FEATURE_FLAGS_PROVIDER=


# =============================================================================
# 12.5. Short links (`@loyalty/shortlinks`)
# Infisical: folder=/api (Worker) + /shared (jobs)  dev=null preview/prod=custom
# =============================================================================
# Self-hosted URL shortener for SMS/WhatsApp links. The redirect (GET /r/:slug)
# is served by the API Worker (apps/api); rows live in the `shortlink` table.
#
# SHORTLINKS_PROVIDER (read by packages/jobs at send time only):
#   - null   (dev): passthrough — `shorten()` returns the URL unchanged.
#   - custom (preview/prod): persists a slug + returns the short URL.
# The Worker doesn't read this — its redirect always works; it only needs the
# base URL below. Default cascade: dev=null, preview/prod=custom.
SHORTLINKS_PROVIDER=
#
# SHORTLINK_BASE_URL — short host + the `/r` path, no trailing slash. Read by
# the Worker (ctx + admin-create URLs) and jobs (custom provider). Per env:
#   - dev:     unset → the Worker lib falls back to http://localhost:8787/r
#   - preview: set per-PR by deploy-preview-worker.ts → https://api.pr-<n>…/r
#   - prod:    https://l.t4diverclub.app/r  (committed in apps/api/wrangler.toml;
#              needs the l.t4diverclub.app route + DNS — Fase 4)
SHORTLINK_BASE_URL=


# =============================================================================
# 12d. Image optimization — Worker cf.image (apps/{web,admin})
# Infisical: folder=/shared  dev=unset preview=unset prod=images.t4diverclub.app
# =============================================================================
# Host (no protocol) of the PUBLIC R2 image domain. When set (together with
# NEXT_PUBLIC_API_URL), the custom Next.js image loader rewrites every R2-hosted
# `<Image>` src to the API Worker's transform endpoint:
#   https://<NEXT_PUBLIC_API_URL>/img/<key>?w=<w>&q=<q>
# The Worker resizes via `fetch(signedR2Url, { cf: { image } })` and serves
# webp/avif. NOTE: the URL-form `/cdn-cgi/image/` does NOT work on our R2-native
# custom domain (resizing can't read it — 403 / cf-resized err=9408), so we
# transform in the Worker. When either env is unset, the loader is a no-op.
#
# Default per env (when unset):
#   - local dev:        no-op (Next default optimizer)
#   - preview deploy:   no-op (same — don't burn transforms per PR)
#   - production:       images.t4diverclub.app  (+ NEXT_PUBLIC_API_URL set)
#
# Setup runbook (prod): see `.claude/skills/image-loader/SKILL.md`.
#   1. R2 bucket → public Custom Domain (images.t4diverclub.app)
#   2. CF zone → Images → Transformations → Enable
#   3. Set NEXT_PUBLIC_IMAGE_CDN_HOST in Infisical /shared (Plain Text)
#   The Worker reads R2 via signed S3 GETs (R2_* creds it already has) — no
#   extra env. Edge caching for `images.` is set once by
#   scripts/cloudflare/set-image-cache-rules.ts (CLOUDFLARE_CACHE_RULES_TOKEN
#   in Infisical /ci).
NEXT_PUBLIC_IMAGE_CDN_HOST=


# =============================================================================
# 13. Background jobs (packages/jobs, Trigger.dev)
# Infisical: folder=/jobs  env=prod
# =============================================================================
# Retention window for the `*_outbox` tables. The `prune-outboxes`
# Trigger.dev task runs daily at 04:00 UTC and deletes rows older
# than this in `email_outbox` / `sms_outbox` / `whatsapp_outbox` /
# `push_outbox`. Defaults to 30 days when unset. Set higher for
# compliance, or pause the task in the Trigger.dev dashboard to
# disable cleanup.
OUTBOX_RETENTION_DAYS=


# =============================================================================
# 14. Optional overrides (only when the cascade isn't enough)
# Infisical: NEXT_PUBLIC_APP_URL → /web · BETTER_AUTH_URL → /admin
#            BETTER_STACK_SOURCE_TOKEN (single-service fallback) → /shared
# Reminder: VERCEL_URL / VERCEL_ENV / VERCEL_PROJECT_PRODUCTION_URL are
# platform-injected — NEVER store them in Infisical.
# =============================================================================
# Most of the time these stay empty. The apps derive their public URL with
# this cascade in apps/{web,admin}/lib/app-url.ts:
#
#   1. Browser → window.location.origin
#   2. Server → explicit env var below (this section)
#   3. Server → VERCEL_URL (auto-injected per Vercel deploy)
#   4. Server → localhost:300{2,3}
#
# Set them ONLY when:
#   - You have a custom production domain (e.g. https://app.t4-loyalty.com).
#   - You want cross-app auth testing in preview deploys (admin's preview
#     URL ≠ web's preview URL, so explicit pinning is needed).
NEXT_PUBLIC_APP_URL=
BETTER_AUTH_URL=

# Single-service Better Stack shortcut. Bootstraps prefer the per-service
# vars above; this is the fallback when you only have one service.
BETTER_STACK_SOURCE_TOKEN=
BETTER_STACK_INGESTING_HOST=in.logs.betterstack.com
