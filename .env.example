# ===========================================
# Database (Neon)
# ===========================================
# Pooled connection string from your Neon project
# (Dashboard -> Connection details -> "Connection pooling" toggle ON)
# Local Postgres alternative: postgresql://root@localhost:5433/db?sslmode=disable
DATABASE_URL=postgresql://user:password@host/db?sslmode=require&channel_binding=require

# ===========================================
# Better Auth
# ===========================================
# Generate with: openssl rand -base64 32 (must be at least 32 chars)
BETTER_AUTH_SECRET=
# Public URL of the app that issues sessions (admin app, port 3003 in dev)
BETTER_AUTH_URL=http://localhost:3003

# Google OAuth (https://console.cloud.google.com -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# Trigger.dev v3 (background jobs)
# ===========================================
# From https://cloud.trigger.dev -> your project -> API Keys
# TRIGGER_PROJECT_ID is required: jobs will throw on boot if missing.
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

# ===========================================
# Better Stack (logs + uptime + status page)
# ===========================================
# Better Stack splits its API into two surfaces and each one needs its own
# token. We register two MCP servers in .mcp.json so the right tool always
# runs against the right surface:
#   - mcp__better-stack__uptime_*       → uses BETTER_STACK_API_TOKEN
#   - mcp__better-stack-telemetry__*    → uses BETTER_STACK_TELEMETRY_API_TOKEN

# Uptime API (monitors, heartbeats, status pages, escalation policies, incidents).
# Generate at https://uptime.betterstack.com/team/api-tokens
#   tab "Team-based tokens" → section "Uptime API tokens" → Create.
BETTER_STACK_API_TOKEN=

# Telemetry API (sources, dashboards, charts, log alerts).
# Generate at https://logs.betterstack.com/team/api-tokens
#   create a "Telemetry API token" scoped to the same team.
BETTER_STACK_TELEMETRY_API_TOKEN=

# Logs source token + ingest host. Get them from
# https://logs.betterstack.com/team/sources -> create a source ("loyalty-app").
# When BETTER_STACK_SOURCE_TOKEN is set, the @loyalty/log default channel
# auto-switches from `pino` to `better-stack`. Leave empty in dev to keep
# logs in the local terminal.
BETTER_STACK_SOURCE_TOKEN=
BETTER_STACK_INGESTING_HOST=in.logs.betterstack.com

# ===========================================
# Logging
# ===========================================
# Override the floor without redeploying. Levels: trace | debug | info | warn | error | fatal | silent.
# In production keep `info` (default); flip to `debug` from the Vercel dashboard
# when you need to inspect a live issue, then revert.
LOG_LEVEL=info

# Force a specific channel even if BETTER_STACK_SOURCE_TOKEN is present.
# Channels: pino | better-stack | console | silent.
# Leave empty to let the bootstrap pick automatically.
LOG_CHANNEL=

# ===========================================
# Slack MCP (@modelcontextprotocol/server-slack)
# ===========================================
# Used by the Slack MCP server registered in .mcp.json.
# 1. Create a Slack app at https://api.slack.com/apps (From scratch).
# 2. OAuth & Permissions -> Bot Token Scopes: channels:history, channels:read,
#    chat:write, reactions:write, users:read, groups:read.
# 3. Install to workspace -> copy the "Bot User OAuth Token" (xoxb-...).
# 4. Settings -> Basic Information -> "App-Level Tokens" not needed.
# 5. Workspace ID (T...): https://<workspace>.slack.com/help/requests/<id> shows it,
#    or run https://api.slack.com/methods/team.info/test once authenticated.
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# ===========================================
# Public (exposed to the browser via NEXT_PUBLIC_*)
# ===========================================
# Web (customer PWA) runs on :3002, Admin runs on :3003.
# Set this to whichever app you point the current build at.
NEXT_PUBLIC_APP_URL=http://localhost:3003
