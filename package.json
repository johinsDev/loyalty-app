{
  "name": "loyalty-app",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.2.10",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/tooling/*",
    "partykit"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "bash scripts/with-infisical.sh turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --filter=!@loyalty/e2e",
    "test:coverage": "turbo run test:coverage --filter=!@loyalty/e2e",
    "e2e": "bun run --cwd apps/e2e test",
    "knip": "knip",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bash scripts/with-infisical.sh bun run --cwd packages/db db:migrate",
    "db:push": "bash scripts/with-infisical.sh bun run --cwd packages/db db:push",
    "db:studio": "bash scripts/with-infisical.sh bun run --cwd packages/db db:studio",
    "db:seed:owner": "bash scripts/with-infisical.sh bun run --cwd packages/db src/seed-owner.ts",
    "jobs:dev": "bash scripts/with-infisical.sh bun run --cwd packages/jobs dev",
    "jobs:deploy": "bun run --cwd packages/jobs deploy",
    "partykit:dev": "bash scripts/with-infisical.sh bun run --cwd partykit dev",
    "partykit:deploy": "bun run --cwd partykit deploy",
    "env:bootstrap": "bash scripts/infisical-bootstrap.sh",
    "env:pull": "infisical export --env=${INFISICAL_ENV:-dev} --recursive --format=dotenv",
    "env:check": "infisical secrets --env=${INFISICAL_ENV:-dev} --recursive",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@commitlint/types": "^19.5.0",
    "@types/bun": "^1.2.0",
    "dotenv-cli": "^11.0.0",
    "knip": "^5.30.0",
    "lefthook": "^1.10.0",
    "oxlint": "^0.15.0",
    "turbo": "^2.9.12",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.2"
  }
}
