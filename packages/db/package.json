{
  "name": "@loyalty/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo node_modules"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@loyalty/address": "workspace:*",
    "drizzle-orm": "^0.36.0"
  },
  "devDependencies": {
    "@loyalty/tsconfig": "workspace:*",
    "drizzle-kit": "^0.28.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.7.0"
  }
}
