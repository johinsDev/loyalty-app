{
  "name": "@loyalty/email-templates",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "email dev --dir emails --port 3008",
    "preview:build": "email build --dir emails --outDir .react-email",
    "preview:export": "email export --dir emails --outDir .react-email/out",
    "lint": "oxlint src emails",
    "format": "oxlint src emails --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo .react-email node_modules"
  },
  "dependencies": {
    "@react-email/components": "^0.0.31",
    "@react-email/render": "^1.0.5"
  },
  "devDependencies": {
    "@loyalty/tsconfig": "workspace:*",
    "@react-email/preview-server": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "oxlint": "^0.15.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-email": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
