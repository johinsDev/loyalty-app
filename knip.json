{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [".claude/worktrees/**"],
  "workspaces": {
    ".": {},
    "apps/admin": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,default,route,sitemap,robots,manifest}.{ts,tsx}",
        "lib/**/*.{ts,tsx}"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "apps/web": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,default,route,sitemap,robots,manifest,icon,apple-icon}.{ts,tsx}",
        "app/sw.ts",
        "components/**/*.{ts,tsx}",
        "lib/**/*.{ts,tsx}"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "apps/e2e": {},
    "apps/storybook": {
      "entry": [".storybook/main.ts", ".storybook/preview.ts", "stories/**/*.stories.{ts,tsx}", "vite.config.ts"],
      "project": ["**/*.{ts,tsx}"],
      "ignore": ["storybook-static/**"]
    },
    "packages/api": {},
    "packages/auth": {},
    "packages/db": {},
    "packages/log": {},
    "packages/ui": {},
    "packages/jobs": { "entry": ["trigger/**/*.ts", "log.ts"] }
  },
  "ignoreDependencies": ["@commitlint/cli", "oxlint", "next"],
  "ignoreExportsUsedInFile": true
}
