{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "scripts/db/create-preview-db.ts",
        "scripts/db/delete-preview-db.ts",
        "scripts/db/mask-preview-db.ts",
        "scripts/vercel/set-preview-env.ts",
        "scripts/vercel/unset-preview-env.ts",
        "scripts/vercel/trigger-preview-deploy.ts",
        "scripts/r2/cleanup-preview-prefix.ts",
        "scripts/cache/flush-preview-namespace.ts"
      ]
    },
    "apps/admin": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,default,route,sitemap,robots,manifest}.{ts,tsx}",
        "src/env.ts",
        "src/lib/auth-guard.ts",
        "src/lib/cache.ts",
        "src/lib/dev-only.ts",
        "src/lib/email.ts",
        "src/lib/push.ts",
        "src/lib/realtime.ts",
        "src/lib/sms.ts",
        "src/lib/storage.ts",
        "src/lib/whatsapp.ts",
        "src/features/realtime/hooks/use-customer-room.ts",
        "src/features/storage/hooks/use-file-upload.ts",
        "src/features/storage/components/file-upload.tsx",
        "src/features/storage/components/rhf-file-upload.tsx",
        "src/lib/image-loader.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": ["@upstash/ratelimit", "@upstash/redis"]
    },
    "apps/web": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,default,route,sitemap,robots,manifest,icon,apple-icon}.{ts,tsx}",
        "app/sw.ts",
        "src/env.ts",
        "src/lib/auth-guard.ts",
        "src/lib/cache.ts",
        "src/lib/email.ts",
        "src/lib/image-loader.ts",
        "src/lib/push.ts",
        "src/lib/push-subscription.ts",
        "src/lib/realtime.ts",
        "src/lib/sms.ts",
        "src/lib/storage.ts",
        "src/lib/whatsapp.ts",
        "src/features/push/hooks/use-push-subscription.ts",
        "src/features/push/components/push-enable-button.tsx",
        "src/features/realtime/hooks/use-customer-room.ts"
      ],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": ["@upstash/ratelimit", "@upstash/redis"]
    },
    "apps/e2e": {},
    "apps/storybook": {
      "entry": ["stories/**/*.stories.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/api": {},
    "packages/auth": {
      "entry": [
        "src/index.ts",
        "src/server.ts",
        "src/client.ts",
        "src/api-guard.ts",
        "src/seed-preview-admin.ts"
      ]
    },
    "packages/date": { "entry": ["src/index.ts", "src/react/index.ts"] },
    "packages/db": {
      "entry": [
        "src/index.ts",
        "src/migrate.ts",
        "src/seed-owner.ts",
        "src/backfill-customers.ts"
      ]
    },
    "packages/log": {},
    "packages/ui": {},
    "packages/cache": {
      "ignoreDependencies": ["@upstash/redis", "ioredis"]
    },
    "packages/rate-limit": {
      "ignoreDependencies": ["@upstash/ratelimit", "@upstash/redis", "ioredis"]
    },
    "packages/analytics": {
      "ignoreDependencies": ["posthog-js", "posthog-node"]
    },
    "packages/feature-flags": {
      "ignoreDependencies": ["posthog-js", "posthog-node"]
    },
    "packages/email": {
      "ignoreDependencies": ["resend"]
    },
    "packages/email-templates": {
      "entry": ["src/index.ts", "emails/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@react-email/preview-server"]
    },
    "packages/push": {
      "ignoreDependencies": ["expo-server-sdk", "web-push"]
    },
    "packages/realtime": {
      "entry": ["src/index.ts", "src/client/index.ts"]
    },
    "partykit": {
      "entry": ["src/server.ts", "src/parties/**/*.ts"]
    },
    "packages/sms": {
      "ignoreDependencies": ["twilio"]
    },
    "packages/storage": {
      "ignoreDependencies": ["@aws-sdk/client-s3", "@aws-sdk/s3-request-presigner"]
    },
    "packages/whatsapp": {
      "ignoreDependencies": ["twilio"]
    },
    "packages/jobs": {
      "entry": ["trigger/**/*.ts", "trigger.config.ts", "log.ts", "whatsapp.ts"]
    }
  },
  "ignoreDependencies": ["@commitlint/cli", "oxlint", "next", "@aws-sdk/client-s3", "@libsql/client"],
  "ignoreBinaries": ["infisical"],
  "ignoreExportsUsedInFile": true
}
