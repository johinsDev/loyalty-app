{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {},
    "apps/admin": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,default,route,sitemap,robots,manifest}.{ts,tsx}",
        "src/env.ts",
        "src/lib/cache.ts",
        "src/lib/sms.ts",
        "src/lib/whatsapp.ts"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "apps/web": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,default,route,sitemap,robots,manifest,icon,apple-icon}.{ts,tsx}",
        "app/sw.ts",
        "src/env.ts",
        "src/lib/cache.ts",
        "src/lib/sms.ts",
        "src/lib/whatsapp.ts"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "apps/e2e": {},
    "apps/storybook": {
      "entry": ["stories/**/*.stories.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/api": {},
    "packages/auth": {},
    "packages/date": { "entry": ["src/index.ts", "src/react/index.ts"] },
    "packages/db": {},
    "packages/log": {},
    "packages/ui": {},
    "packages/cache": {
      "ignoreDependencies": ["@upstash/redis", "ioredis"]
    },
    "packages/sms": {
      "ignoreDependencies": ["twilio"]
    },
    "packages/whatsapp": {
      "ignoreDependencies": ["twilio"]
    },
    "packages/jobs": {
      "entry": ["trigger/**/*.ts", "trigger.config.ts", "log.ts", "whatsapp.ts"]
    }
  },
  "ignoreDependencies": ["@commitlint/cli", "oxlint", "next"],
  "ignoreExportsUsedInFile": true
}
