{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {},
    "apps/admin": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,default,route,sitemap,robots,manifest}.{ts,tsx}",
        "src/env.ts",
        "src/lib/cache.ts",
        "src/lib/email.ts",
        "src/lib/push.ts",
        "src/lib/realtime.ts",
        "src/lib/sms.ts",
        "src/lib/storage.ts",
        "src/lib/whatsapp.ts"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "apps/web": {
      "entry": [
        "app/**/{page,layout,loading,error,not-found,template,default,route,sitemap,robots,manifest,icon,apple-icon}.{ts,tsx}",
        "app/sw.ts",
        "src/env.ts",
        "src/lib/cache.ts",
        "src/lib/email.ts",
        "src/lib/push.ts",
        "src/lib/push-subscription.ts",
        "src/lib/realtime.ts",
        "src/lib/sms.ts",
        "src/lib/storage.ts",
        "src/lib/whatsapp.ts",
        "src/features/push/hooks/use-push-subscription.ts",
        "src/features/push/components/push-enable-button.tsx",
        "src/features/realtime/hooks/use-customer-room.ts",
        "src/features/realtime/components/connection-badge.tsx",
        "src/features/storage/hooks/use-file-upload.ts",
        "src/features/storage/components/file-upload.tsx",
        "src/features/storage/components/rhf-file-upload.tsx"
      ],
      "project": ["**/*.{ts,tsx}"]
    },
    "apps/e2e": {},
    "apps/storybook": {
      "entry": ["stories/**/*.stories.{ts,tsx}"],
      "project": ["**/*.{ts,tsx}"]
    },
    "packages/api": {},
    "packages/auth": {},
    "packages/date": { "entry": ["src/index.ts", "src/react/index.ts"] },
    "packages/db": {},
    "packages/log": {},
    "packages/ui": {},
    "packages/cache": {
      "ignoreDependencies": ["@upstash/redis", "ioredis"]
    },
    "packages/email": {
      "ignoreDependencies": ["resend"]
    },
    "packages/email-templates": {
      "entry": ["src/index.ts", "emails/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@react-email/preview-server"]
    },
    "packages/push": {
      "ignoreDependencies": ["expo-server-sdk", "web-push"]
    },
    "packages/realtime": {
      "entry": ["src/index.ts", "src/client/index.ts"]
    },
    "partykit": {
      "entry": ["src/server.ts", "src/parties/**/*.ts"]
    },
    "packages/sms": {
      "ignoreDependencies": ["twilio"]
    },
    "packages/storage": {
      "ignoreDependencies": ["@aws-sdk/client-s3", "@aws-sdk/s3-request-presigner"]
    },
    "packages/whatsapp": {
      "ignoreDependencies": ["twilio"]
    },
    "packages/jobs": {
      "entry": ["trigger/**/*.ts", "trigger.config.ts", "log.ts", "whatsapp.ts"]
    }
  },
  "ignoreDependencies": ["@commitlint/cli", "oxlint", "next"],
  "ignoreExportsUsedInFile": true
}
