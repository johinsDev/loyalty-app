{
  "extends": "@loyalty/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [".storybook", "stories", "vite.config.ts"],
  "exclude": ["node_modules", "storybook-static"]
}
