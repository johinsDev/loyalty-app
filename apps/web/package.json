{
  "name": "@loyalty/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev --turbopack --port 3002",
    "build": "dotenv -e ../../.env -- next build",
    "start": "dotenv -e ../../.env -- next start --port 3002",
    "lint": "oxlint app components lib i18n middleware.ts",
    "format": "oxlint app components lib i18n middleware.ts --fix",
