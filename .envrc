# direnv: load every var from .env into the shell when you cd into this repo.
# This is the easiest way to feed Claude Code's HTTP MCP servers
# (Better Stack, Linear) which read tokens like ${BETTER_STACK_API_TOKEN}
# from the *process* environment, not from the project .env file.
#
# Setup (once per machine):
#   brew install direnv
#   echo 'eval "$(direnv hook zsh)"' >> ~/.zshrc   # or your shell of choice
#   direnv allow .
#
# After that, every shell session that cd's into this repo gets the
# .env loaded. Launch `claude` from that shell and the MCP handshakes
# pick the tokens up automatically.
dotenv
